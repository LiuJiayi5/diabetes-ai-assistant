kind: rag_pipeline
rag_pipeline:
  description: 'Route uploaded documents by file type: Markdown files go directly
    to text extraction, while Office/HTML/TXT/XML/CSV files are converted through
    MarkItDown before parent-child chunking.'
  icon: 📙
  icon_background: '#FFF4ED'
  icon_type: emoji
  icon_url: null
  name: Smart Diabetes KB Import Pipeline
version: 0.1.0
workflow:
  conversation_variables: []
  environment_variables:
  - description: ''
    id: 20933693-a8e1-47f0-84df-d4c671454d8b
    name: FILES_URL
    selector:
    - env
    - FILES_URL
    value: http://localhost
    value_type: string
  features: {}
  graph:
